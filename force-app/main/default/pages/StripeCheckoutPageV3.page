<apex:page
    controller="StripeCheckoutController"
    showHeader="false"
    sidebar="false"
    standardStylesheets="false"
    cache="false"
    docType="html-5.0"
>
    <html>
        <head>
            <title>Checkout</title>
            <meta name="viewport" content="width=device-width, initial-scale=1.0" />
            <script src="https://js.stripe.com/clover/stripe.js"></script>
            <link rel="icon" type="image/png" href="{!URLFOR($Resource.Displai)}" />
            <link rel="preconnect" href="https://fonts.googleapis.com" />
            <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
            <link
                href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&amp;display=swap"
                rel="stylesheet"
            />
            <style>
                /* =====================================================
               RESET &amp; TOKENS
               ===================================================== */
                *,
                *::before,
                *::after {
                    box-sizing: border-box;
                    margin: 0;
                    padding: 0;
                }

                :root {
                    --c-bg: #ffffff;
                    --c-surface: #f6f8fa;
                    --c-border: #e3e8ef;
                    --c-border-2: #cdd3dc;
                    --c-text-1: #0d1117;
                    --c-text-2: #5c6370;
                    --c-text-3: #9ca3af;
                    --c-accent: #635bff;
                    --c-accent-dark: #4f46e5;
                    --c-green: #16a34a;
                    --c-green-bg: #f0fdf4;
                    --c-green-bd: #bbf7d0;
                    --c-purple-bg: #f5f3ff;
                    --c-purple-bd: #ddd6fe;
                    --c-purple-txt: #5b21b6;
                    --c-red: #dc2626;
                    --c-success: #22c55e;
                    --r-md: 8px;
                    --r-lg: 12px;
                    --r-pill: 999px;
                }

                body {
                    font-family:
                        "Inter",
                        -apple-system,
                        BlinkMacSystemFont,
                        sans-serif;
                    background: var(--c-bg);
                    color: var(--c-text-1);
                    -webkit-font-smoothing: antialiased;
                    font-size: 14px;
                    line-height: 1.5;
                }

                /* =====================================================
               EXPIRED / COMPLETE STATE
               ===================================================== */
                .container1 {
                    max-width: 280px;
                    margin: 200px auto;
                    text-align: center;
                    color: var(--c-text-2);
                }
                .container1 h4 {
                    font-size: 16px;
                    font-weight: 600;
                    color: var(--c-text-1);
                    margin-bottom: 6px;
                }
                .container1 p {
                    font-size: 13px;
                }

                /* =====================================================
               PAGE LAYOUT
               Single viewport-height flex row. Each column scrolls
               independently through the window — the page scrolls as
               one, not two separate panels.
               ===================================================== */
                .container {
                    width: 100%;
                    min-height: 100vh;
                    display: grid;
                    /* left: slightly wider than right */
                    grid-template-columns: 53fr 47fr;
                    align-items: stretch;
                }

                /* =====================================================
               LEFT — ORDER SUMMARY
               No overflow / no sticky. Flows naturally with the page.
               ===================================================== */
                .summary {
                    /* light grey background, full height */
                    padding: 52px 7% 64px 7%;
                    /* The shadow that acts as the divider — inset on the RIGHT edge */
                    box-shadow: inset -12px 0 20px -12px rgba(0, 0, 0, 0.09);
                }

                .summary > img {
                    display: block;
                    margin-bottom: 28px;
                    /* original inline style kept on element */
                }

                .summary h1 {
                    font-size: 13px;
                    font-weight: 500;
                    color: var(--c-text-2);
                    margin-bottom: 4px;
                    letter-spacing: 0.01em;
                }

                /* Big price */
                .price {
                    font-size: 40px;
                    font-weight: 700;
                    color: var(--c-text-1);
                    letter-spacing: -1.5px;
                    line-height: 1;
                    margin-bottom: 28px;
                }
                .interval {
                    font-size: 13px;
                    font-weight: 500;
                    color: var(--c-text-2);
                    letter-spacing: 0;
                }

                /* ── Contract meta card — 2-column grid, NO row borders ── */
                .contract-card {
                    background: var(--c-surface);
                    border: 1px solid var(--c-border);
                    border-radius: var(--r-lg);
                    padding: 16px 18px;
                    margin-bottom: 28px;
                    /* 2 columns, each cell = label on top, value below */
                    display: grid;
                    grid-template-columns: 1fr 1fr;
                    gap: 14px 12px;
                }
                /* Each .contract-row is now a single grid cell (label + value stacked) */
                .contract-row {
                    display: flex;
                    flex-direction: column;
                    gap: 2px;
                    /* NO border — cells sit in the grid with gap only */
                }
                .contract-label {
                    font-size: 10px;
                    font-weight: 600;
                    text-transform: uppercase;
                    letter-spacing: 0.07em;
                    color: var(--c-text-3);
                }
                .contract-value {
                    font-size: 13px;
                    font-weight: 600;
                    color: var(--c-text-1);
                }

                /* ── Section label ── */
                .section-label {
                    font-size: 10px;
                    font-weight: 600;
                    text-transform: uppercase;
                    letter-spacing: 0.08em;
                    color: var(--c-text-3);
                    margin-bottom: 10px;
                }

                /* ── Line item blocks ──
               JS wraps each item in div class="li-block">.
               Border only between blocks (+ selector), never inside.  */
                .li-block {
                    padding: 14px 0;
                }
                .li-block + .li-block {
                    border-top: 1px solid var(--c-border);
                }

                /* Name row: name left, price right */
                .line-item-name-row {
                    display: flex;
                    justify-content: space-between;
                    align-items: flex-start;
                    gap: 12px;
                    margin-bottom: 2px;
                }

                /* Description line (optional) */
                .product-desc {
                    font-size: 12px;
                    color: var(--c-text-2);
                    margin-bottom: 6px;
                }

                /* Breakdown line: "2 × $300.00 / year" */
                .li-breakdown {
                    font-size: 12px;
                    color: var(--c-text-3);
                    margin-bottom: 6px;
                }

                .old-price {
                    text-decoration: line-through;
                    margin-right: 10px;
                }

                /* Sub-row: qty bubble + billing label LEFT, discount pill RIGHT */
                .line-item-sub-row {
                    display: flex;
                    justify-content: space-between;
                    align-items: center;
                    flex-wrap: wrap;
                    gap: 6px;
                }
                .li-sub-left {
                    display: flex;
                    align-items: center;
                    gap: 6px;
                    flex-wrap: wrap;
                }

                /* Qty badge — pill shape */
                .qty-badge {
                    display: inline-flex;
                    align-items: center;
                    font-size: 11px;
                    font-weight: 500;
                    padding: 2px 9px;
                    border-radius: var(--r-pill);
                    background: var(--c-surface);
                    border: 1px solid var(--c-border-2);
                    color: var(--c-text-2);
                    white-space: nowrap;
                }
                .billing-label {
                    font-size: 12px;
                    color: var(--c-text-3);
                }

                /* Price block */
                .item-price-block {
                    text-align: right;
                    flex-shrink: 0;
                }
                .item-list-price {
                    font-size: 12px;
                    color: var(--c-text-3);
                    text-decoration: line-through;
                    line-height: 1.3;
                }
                .item-final-price {
                    font-size: 14px;
                    font-weight: 700;
                    color: var(--c-text-1);
                    line-height: 1.3;
                }

                /* Discount pills */
                .discount-pill {
                    display: inline-flex;
                    align-items: center;
                    gap: 3px;
                    font-size: 11px;
                    font-weight: 600;
                    padding: 2px 8px;
                    border-radius: var(--r-pill);
                    white-space: nowrap;
                }
                .discount-pct {
                    background: var(--c-green-bg);
                    color: var(--c-green);
                    border: 1px solid var(--c-green-bd);
                }
                .discount-flat {
                    background: var(--c-purple-bg);
                    color: var(--c-purple-txt);
                    border: 1px solid var(--c-purple-bd);
                }

                /* ── Totals block ── */
                .totals-block {
                    margin-top: 20px;
                    padding-top: 16px;
                }
                .totals-block-discount {
                    margin-top: 20px;
                    padding-top: 16px;
                    border-top: 1px solid var(--c-border);
                }
                .totals-row {
                    display: flex;
                    justify-content: space-between;
                    font-size: 13px;
                    color: var(--c-text-2);
                    margin-bottom: 6px;
                }
                .totals-row--discount {
                    color: var(--c-green);
                }
                .totals-row--total {
                    font-size: 14px;
                    font-weight: 700;
                    color: var(--c-text-1);
                    padding-top: 10px;
                    margin-top: 6px;
                    border-top: 1px solid var(--c-border);
                    margin-bottom: 10px;
                }
                .totals-savings {
                    font-size: 12px;
                    color: var(--c-green);
                    display: flex;
                    align-items: center;
                    gap: 5px;
                }

                /* =====================================================
               RIGHT — CHECKOUT FORM
               No border-left — shadow on .summary handles the divide.
               ===================================================== */
                .checkout {
                    padding: 52px 7% 64px 7%;
                    min-height: 100vh;
                }

                .section {
                    margin-bottom: 28px;
                }
                .section h2 {
                    font-size: 11px;
                    font-weight: 700;
                    text-transform: uppercase;
                    letter-spacing: 0.07em;
                    color: var(--c-text-2);
                    margin-bottom: 14px;
                    padding-bottom: 8px;
                    border-bottom: 1px solid var(--c-border);
                }

                label {
                    font-size: 11px;
                    font-weight: 600;
                    display: block;
                    margin-bottom: 5px;
                    color: var(--c-text-2);
                    text-transform: uppercase;
                    letter-spacing: 0.04em;
                }

                .input-box,
                select {
                    width: 100%;
                    padding: 10px 12px;
                    font-size: 14px;
                    font-family: inherit;
                    color: var(--c-text-1);
                    background: var(--c-bg);
                    border: 1px solid var(--c-border-2);
                    border-radius: var(--r-md);
                    transition:
                        border-color 0.15s,
                        box-shadow 0.15s;
                    -webkit-appearance: none;
                }
                .input-box::placeholder {
                    color: var(--c-text-3);
                }
                .input-box:focus,
                select:focus {
                    outline: none;
                    border-color: var(--c-accent);
                    box-shadow: 0 0 0 3px rgba(99, 91, 255, 0.15);
                }

                /* ── Payment element ── */
                #payment,
                #shipping-address {
                    display: none;
                }
                #payment.show,
                #shipping-address.show {
                    display: block;
                }

                /* ── TOS ── */
                .tos {
                    font-size: 12px;
                    color: var(--c-text-2);
                }
                .tos a {
                    color: var(--c-accent);
                    text-decoration: none;
                }
                .tos a:hover {
                    text-decoration: underline;
                }

                .tos-scroll-wrapper {
                    position: relative;
                    margin-bottom: 14px;
                }
                .tos-scroll-box {
                    height: 250px;
                    overflow-y: scroll;
                    border: 1px solid var(--c-border-2);
                    border-radius: var(--r-md);
                    padding: 12px 14px;
                    font-size: 11px;
                    line-height: 1.6;
                    color: var(--c-text-2);
                    background: var(--c-surface);
                    box-sizing: border-box;
                }
                .tos-scroll-box h3 {
                    font-size: 12px;
                    font-weight: 700;
                    color: var(--c-text-1);
                    margin: 0 0 8px 0;
                }
                .tos-scroll-box p {
                    margin: 0 0 10px 0;
                }
                .tos-scroll-box .tos-section {
                    margin-bottom: 12px;
                }
                .tos-scroll-box .tos-section-title {
                    font-weight: 700;
                    color: var(--c-text-1);
                }

                .tos-scroll-hint {
                    font-size: 11px;
                    color: var(--c-accent);
                    text-align: center;
                    margin-bottom: 5px;
                    font-weight: 500;
                    transition: color 0.2s;
                }
                .tos-scroll-hint.hidden {
                    opacity: 0;
                    pointer-events: none;
                }

                .terms {
                    display: flex;
                    align-items: flex-start;
                    gap: 10px;
                }
                .terms input[type="checkbox"] {
                    width: 15px;
                    height: 15px;
                    margin-top: 2px;
                    accent-color: var(--c-accent);
                    flex-shrink: 0;
                }
                .terms p {
                    font-size: 12px;
                    line-height: 1.5;
                }

                #terms-checkbox:disabled {
                    opacity: 0.35;
                    cursor: not-allowed;
                }
                #terms-checkbox:not(:disabled) {
                    cursor: pointer;
                }

                /* ── Submit button ── */
                .submit-btn {
                    position: relative;
                    width: 100%;
                    background: var(--c-accent);
                    color: #fff;
                    font-family: inherit;
                    font-size: 14px;
                    font-weight: 600;
                    border: none;
                    border-radius: var(--r-md);
                    padding: 16px 24px;
                    cursor: pointer;
                    margin-top: 12px;
                    letter-spacing: 0.01em;
                    transition:
                        background 0.2s,
                        box-shadow 0.2s,
                        transform 0.1s;
                }
                .submit-btn:hover:not(:disabled) {
                    background: var(--c-accent-dark);
                    box-shadow: 0 4px 14px rgba(99, 91, 255, 0.35);
                }
                .submit-btn:active:not(:disabled) {
                    transform: translateY(1px);
                }
                .submit-btn:disabled {
                    background: var(--c-border-2);
                    color: var(--c-text-3);
                    cursor: not-allowed;
                    box-shadow: none;
                }

                /* Spinner hidden by default */
                .btn-spinner {
                    position: absolute;
                    top: 50%;
                    right: 18px;
                    transform: translateY(-50%);
                    width: 16px;
                    height: 16px;
                    border: 2px solid rgba(255, 255, 255, 0.35);
                    border-top: 2px solid #ffffff;
                    border-radius: 50%;
                    animation: spin 0.6s linear infinite;
                    display: none;
                }

                /* When loading */
                .submit-btn.loading .btn-spinner {
                    display: block;
                }

                /* Smooth spin */
                @keyframes spin {
                    from {
                        transform: translateY(-50%) rotate(0deg);
                    }
                    to {
                        transform: translateY(-50%) rotate(360deg);
                    }
                }

                /* ── Toast ── */
                .toast {
                    position: fixed;
                    top: 24px;
                    right: 24px;
                    background: var(--c-text-1);
                    color: white;
                    padding: 12px 18px;
                    border-radius: var(--r-md);
                    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18);
                    opacity: 0;
                    transform: translateX(16px);
                    pointer-events: none;
                    transition:
                        opacity 0.25s,
                        transform 0.25s;
                    z-index: 9999;
                    min-width: 240px;
                    font-size: 13px;
                    font-weight: 500;
                }
                .toast.show {
                    opacity: 1;
                    transform: translateX(0);
                    pointer-events: auto;
                }
                .toast.error {
                    background: var(--c-red);
                }
                .toast.success {
                    background: var(--c-success);
                }

                /* ── Footer notes ── */
                .footer {
                    font-size: 11px;
                    color: var(--c-text-3);
                    text-align: center;
                    margin-top: 14px;
                    line-height: 1.5;
                }

                /* =====================================================
               RESPONSIVE
               ===================================================== */
                @media (max-width: 900px) {
                    .container {
                        grid-template-columns: 1fr;
                    }
                    .summary {
                        box-shadow: none;
                        border-bottom: 1px solid var(--c-border);
                        padding: 32px 5%;
                    }
                    .checkout {
                        padding: 32px 5%;
                        min-height: auto;
                    }
                }
                @media (max-width: 640px) {
                    .price {
                        font-size: 32px;
                    }
                    .contract-card {
                        grid-template-columns: 1fr;
                    }
                    .tos-scroll-box {
                        height: 200px;
                    }
                    .toast {
                        top: 16px;
                        right: 16px;
                        left: 16px;
                        min-width: unset;
                    }
                }
            </style>
        </head>

        <body>
            <!-- EXPIRED STATE &amp; COMPLETE STATE -->
            <apex:outputPanel rendered="{!OR(status == 'complete', status == 'expired')}">
                <div class="container1">
                    <h4>You're all done here</h4>
                    <p>You've either completed your payment or this checkout session has timed out.</p>
                </div>
            </apex:outputPanel>

            <!-- OPEN STATE -->
            <apex:outputPanel rendered="{!status == 'open'}">
                <div class="container">
                    <!-- LEFT -->
                    <div class="summary">
                        <img
                            src="{!URLFOR($Resource.DisplaiLogo)}"
                            alt="Displai Logo"
                            width="120"
                            style="margin: -22px 0 -8px 0"
                        />

                        <h1>{!subscriptionHeadline}</h1>

                        <div class="price">
                            <span id="price-value"></span>
                            <apex:outputPanel rendered="{!AND(onetimeItemCount = 0, recurringItemCount > 0)}">
                                <span class="interval">per {!LOWER(interval)}</span>
                            </apex:outputPanel>
                            <apex:outputPanel rendered="{!AND(onetimeItemCount > 0, recurringItemCount > 0)}">
                                <p class="interval">Then ${!recurringAmount} every {!LOWER(interval)}</p>
                            </apex:outputPanel>
                        </div>

                        <div class="contract-card">
                            <!-- 2-column grid: each .contract-row is one cell (label stacked above value) -->
                            <div class="contract-row">
                                <span class="contract-label">Quote</span>
                                <span class="contract-value" style="color: var(--c-accent)"
                                    >#{!quoteData.quoteNumber}</span
                                >
                            </div>
                            <div class="contract-row">
                                <span class="contract-label">Term</span>
                                <span class="contract-value">{!quoteData.agreementTerm}</span>
                            </div>
                            <div class="contract-row">
                                <span class="contract-label">Starts</span>
                                <span class="contract-value">
                                    <apex:outputText value="{0, date, MMMM d',' yyyy}">
                                        <apex:param value="{!quoteData.startDate}" />
                                    </apex:outputText>
                                </span>
                            </div>
                            <div class="contract-row">
                                <span class="contract-label">Ends</span>
                                <span class="contract-value">
                                    <apex:outputText value="{0, date, MMMM d',' yyyy}">
                                        <apex:param value="{!quoteData.endDate}" />
                                    </apex:outputText>
                                </span>
                            </div>
                            <div class="contract-row">
                                <span class="contract-label">Sales Rep</span>
                                <span class="contract-value">{!quoteData.salesRepName}</span>
                            </div>
                        </div>

                        <div class="section-label">Line Items</div>
                        <div id="line-items-container"></div>
                    </div>

                    <!-- RIGHT -->
                    <div class="checkout">
                        <!-- BILLING CONTACT -->
                        <div class="section">
                            <h2>Billing contact</h2>
                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 10px">
                                <div>
                                    <label for="billing-first-name">First name *</label>
                                    <input
                                        id="billing-first-name"
                                        class="input-box"
                                        type="text"
                                        value="{!quoteData.billToFirstName}"
                                        placeholder="First name"
                                    />
                                </div>
                                <div>
                                    <label for="billing-last-name">Last name *</label>
                                    <input
                                        id="billing-last-name"
                                        class="input-box"
                                        type="text"
                                        value="{!quoteData.billToLastName}"
                                        placeholder="Last name"
                                    />
                                </div>
                            </div>
                            <label for="billing-email">Billing email *</label>
                            <input
                                id="billing-email"
                                class="input-box"
                                type="email"
                                value="{!quoteData.billToEmail}"
                                placeholder="billing@company.com"
                            />
                        </div>

                        <!-- SHIPPING ADDRESS -->
                        <div class="section">
                            <h2>Shipping address</h2>
                            <div style="margin-bottom: 10px">
                                <label for="shipping-street">Street *</label>
                                <input
                                    id="shipping-street"
                                    class="input-box"
                                    type="text"
                                    value="{!quoteData.shippingStreet}"
                                    placeholder="123 Main St"
                                />
                            </div>
                            <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 10px; margin-bottom: 10px">
                                <div>
                                    <label for="shipping-city">City *</label>
                                    <input
                                        id="shipping-city"
                                        class="input-box"
                                        type="text"
                                        value="{!quoteData.shippingCity}"
                                        placeholder="City"
                                    />
                                </div>
                                <div>
                                    <label for="shipping-state">State *</label>
                                    <input
                                        id="shipping-state"
                                        class="input-box"
                                        type="text"
                                        value="{!quoteData.shippingState}"
                                        placeholder="CA"
                                        maxlength="2"
                                        style="text-transform: uppercase"
                                    />
                                </div>
                            </div>
                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px">
                                <div>
                                    <label for="shipping-postal">Postal code *</label>
                                    <input
                                        id="shipping-postal"
                                        class="input-box"
                                        type="text"
                                        value="{!quoteData.shippingPostalCode}"
                                        placeholder="90210"
                                    />
                                </div>
                                <div>
                                    <label for="shipping-country">Country</label>
                                    <input
                                        id="shipping-country"
                                        class="input-box"
                                        type="text"
                                        value="{!quoteData.shippingCountry}"
                                        placeholder="US"
                                        maxlength="2"
                                        style="text-transform: uppercase"
                                    />
                                </div>
                            </div>
                        </div>

                        <div id="payment" class="section">
                            <h2>Payment method</h2>
                            <div id="payment-element"></div>
                        </div>

                        <div class="section tos">
                            <!-- ===== SCROLLABLE TC BOX ===== -->
                            <div class="tos-scroll-wrapper">
                                <div class="tos-scroll-hint" id="tos-scroll-hint">
                                    &#8595; You must scroll through and read all terms to enable the checkbox below
                                </div>
                                <div class="tos-scroll-box" id="tos-scroll-box" onscroll="handleTosScroll(this)">
                                    <h3>DISPLAI SYSTEMS INC. MASTER SERVICES AGREEMENT</h3>
                                    <p>
                                        This Master Services Agreement (this "Agreement") governs the purchase and use
                                        of (a) third party hardware ("Products"), (b) Displai offerings sold on a
                                        subscription basis for a specified term ("Subscriptions"), and (c) professional
                                        and other services provided by Displai Systems Inc. (together with its
                                        Affiliates, "Displai") ("Services"), and the entity named on the purchase order
                                        or SOW, as applicable, accepted by Displai (each, an "Order") (together with its
                                        Affiliates, "Customer"). "Affiliate" means any entity controlled by,
                                        controlling, or under common control with a party.
                                    </p>

                                    <div class="tos-section">
                                        <p>
                                            <span class="tos-section-title">1. Orders.</span> Any purchase of Products,
                                            Subscriptions and/or Services by Customer shall be made pursuant to an
                                            Order, each of which shall be deemed accepted upon the earlier of Displai's
                                            written confirmation, provisioning of Subscription(s), commencement of
                                            Services, or purchase of products or services for Displai's fulfillment of
                                            the Order. Products, Subscriptions and Services are further described by and
