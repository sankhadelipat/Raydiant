            <script>
                const stripe = Stripe("{!publishableKey}");
                const clientSecret = "{!clientSecret}";
                const checkoutSessionId = "{!sessionId}";

                let checkout;
                let actions;
                let paymentInProgress = false;

                initializeCheckout();

                async function initializeCheckout() {
                    const appearance = {
                        theme: "stripe",
                        inputs: "condensed",
                        labels: "floating",
                        variables: {
                            colorPrimary: "#635bff",
                            colorText: "#1a1f36",
                            colorBackground: "#ffffff",
                            colorDanger: "#e55353",
                            fontFamily: "Inter, -apple-system, BlinkMacSystemFont, sans-serif",
                            spacingUnit: "4px",
                            borderRadius: "6px"
                        },
                        rules: {
                            ".Input": {
                                backgroundColor: "#ffffff",
                                borderColor: "#d0d5dd",
                                boxShadow: "0 1px 2px 0 rgba(18, 52, 86, 0.05)",
                                padding: "10px 12px",
                                fontSize: "14px"
                            },
                            ".Input:focus": {
                                borderColor: "#635bff",
                                boxShadow: "0 1px 2px 0 rgba(99, 91, 255, 0.3)"
                            },
                            ".Input--error": {
                                borderColor: "#e55353",
                                boxShadow: "0 1px 2px 0 rgba(229, 83, 83, 0.3)"
                            },
                            ".Label": {
                                fontSize: "12px",
                                fontWeight: "500"
                            },
                            ".Label--floating": {
                                fontSize: "12px",
                                fontWeight: "500"
                            },
                            ".Label--resting": {
                                color: "#697386",
                                fontSize: "14px"
                            },
                            ".Error": {
                                color: "#e55353",
                                fontSize: "12px"
                            }
                        }
                    };

                    checkout = stripe.initCheckout({
                        clientSecret: clientSecret,
                        elementsOptions: {
                            appearance,
                            loader: "always",
                            fonts: [
                                {
                                    cssSrc: "https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&amp;display=swap"
                                }
                            ]
                        }
                    });

                    checkout.on("change", (session) => {
                        console.log("Checkout change event:", session);
                    });

                    const loadActionResult = await checkout.loadActions();
                    if (loadActionResult.type === "success") {
                        actions = loadActionResult.actions;
                        const session = loadActionResult.actions.getSession();
                        document.getElementById("price-value").textContent = session.total.total.amount;
                        console.log("Checkout actions loaded:", actions);
                    }

                    const paymentElement = checkout.createPaymentElement({
                        layout: {
                            type: "accordion",
                            defaultCollapsed: true,
                            radios: true,
                            spacedAccordionItems: false,
                            paymentMethodLogoPosition: "start"
                        }
                    });
                    paymentElement.mount("#payment-element");
                    document.getElementById("payment").classList.add("show");

                    // Shipping address is captured via native HTML fields — no Stripe element needed
                }

                // ── Line item rendering ──────────────────────────────────────────
                // MRR__c = total monthly amount for this line (all units combined)
                // Per-unit monthly price = MRR__c / effectiveQty
                // Cycle total (what customer pays per invoice) = (MRR / qty) × qty × months
                //   which simplifies to: MRR × months  (for recurring)
                // List cycle total (for strikethrough) = listPrice × qty × months

                // Map billing frequency to interval and count for amount calculations
                const freqMap = {
                    "Monthly": ["month", 1],
                    "Quarterly": ["month", 3],
                    "Semiannual": ["month", 6],
                    "Annual": ["year", 1],
                    "2-Year": ["year", 2],
                    "3-Year": ["year", 3]
                };

                function calculateListPrice(amount, interval, intervalCount) {
                    if (interval === "month") {
                        return amount * intervalCount;
                    } else if (interval === "year") {
                        return amount * (intervalCount * 12);
                    }
                    return amount; // Default fallback
                }

                function calculateFlatDiscount(listAmount, finalAmount) {
                    const discount = (listAmount - finalAmount).toFixed(2);
                    return discount > 0 ? parseFloat(discount) : 0;
                }

                // What the customer is actually charged per billing cycle for this line
                function cycleAmount(li) {
                    // One-time items: NetTotal is the full charge — show as it is
                    if (li.chargeType !== 'Recurring') {
                        return li.netTotal;
                    }
                    // Recurring: CPQ MRR__c is always monthly total.
                    // Multiply by interval count to get the full cycle amount for display (e.g. Quarterly = 3 months of MRR)
                    const freq = li.billingFreqOverride || "{!quoteData.billingFrequencyOverride}";

                    const interval = freqMap[freq] ? freqMap[freq][0] : "month";
                    const intervalCount = freqMap[freq] ? freqMap[freq][1] : 1;

                    const qty = li.effectiveQty;
                    const lineAmount = li.mrr != null && li.mrr != 0
                        ? li.mrr
                        : li.subscriptionTerm != null && li.subscriptionTerm != 0
                            ? li.netTotal / li.subscriptionTerm
                            : li.netTotal; // Fallback to NetTotal if MRR unavailable

                    return parseFloat(calculateListPrice(lineAmount, interval, intervalCount).toFixed(2));
                }

                // Undiscounted cycle total for strikethrough
                // listPrice is per-unit (CPQ standard), so: listPrice × qty × months
                function listCycleAmount(li) {
                    if (li.chargeType !== 'Recurring') {
                        // list equivalent for one-time: listPrice × qty
                        return parseFloat((li.listPrice * li.effectiveQty).toFixed(2));
                    }

                    const freq = li.billingFreqOverride || "{!quoteData.billingFrequencyOverride}";

                    const interval = freqMap[freq] ? freqMap[freq][0] : "month";
                    const intervalCount = freqMap[freq] ? freqMap[freq][1] : 1;

                    const qty = li.effectiveQty;
                    const lineAmount = li.listPrice != null && li.listPrice != 0
                        ? li.listPrice * qty
                        : li.subscriptionTerm != null && li.subscriptionTerm != 0
                            ? li.netTotal / li.subscriptionTerm
                            : li.netTotal; // Fallback to NetTotal if MRR unavailable

                    return parseFloat(calculateListPrice(lineAmount, interval, intervalCount).toFixed(2));
                }

                // Per-unit price per billing cycle — shown as the right-hand "unit note"
                // e.g. Annual: (MRR / qty) × 12 = $691.32 / unit / year
                function unitCycleAmount(li) {
                    // One-time items: NetTotal / quantity
                    if (li.chargeType !== 'Recurring') {
                        return parseFloat((li.netTotal / li.effectiveQty).toFixed(2));
                    }

                    const freq = li.billingFreqOverride || "{!quoteData.billingFrequencyOverride}";

                    const interval = freqMap[freq] ? freqMap[freq][0] : "month";
                    const intervalCount = freqMap[freq] ? freqMap[freq][1] : 1;

                    const qty = li.effectiveQty;
                    const lineAmount = li.mrr != null && li.mrr != 0
                        ? li.mrr / qty
                        : li.subscriptionTerm != null && li.subscriptionTerm != 0
                            ? li.netTotal / li.subscriptionTerm / qty
                            : li.netTotal; // Fallback to NetTotal if MRR unavailable

                    return parseFloat(calculateListPrice(lineAmount, interval, intervalCount).toFixed(2));
                }

                // List (undiscounted) per-unit per cycle
                function listUnitCycleAmount(li) {
                    if (li.chargeType !== 'Recurring') {
                        // list equivalent for one-time: listPrice × qty
                        return li.listPrice;
                    }

                    const freq = li.billingFreqOverride || "{!quoteData.billingFrequencyOverride}";

                    const interval = freqMap[freq] ? freqMap[freq][0] : "month";
                    const intervalCount = freqMap[freq] ? freqMap[freq][1] : 1;

                    const qty = li.effectiveQty;
                    const lineAmount = li.listPrice != null && li.listPrice != 0
                        ? li.listPrice
                        : li.subscriptionTerm != null && li.subscriptionTerm != 0
                            ? li.netTotal / li.subscriptionTerm / qty
                            : li.netTotal; // Fallback to NetTotal if MRR unavailable

                    return parseFloat(calculateListPrice(lineAmount, interval, intervalCount).toFixed(2));
                }

                function cycleLabel(freq) {
                    const interval = freqMap[freq] ? freqMap[freq][0] : "month";
                    const intervalCount = freqMap[freq] ? freqMap[freq][1] : 1;

                    switch (interval) {
                        case "month":
                            return intervalCount > 1 ? `Billed every ${intervalCount} months` : 'Billed monthly';
                        case "year":
                            return intervalCount > 1 ? `Billed every ${intervalCount} years` : 'Billed annually';
                        default:
                            return intervalCount > 1 ? `Billed every ${intervalCount} ${interval}` : `Billed ${interval}`;
                    }
                }

                function freqIntervalLabel(freq) {
                    const interval = freqMap[freq] ? freqMap[freq][0] : "month";
                    const intervalCount = freqMap[freq] ? freqMap[freq][1] : 1;

                    switch (interval) {
                        case "month":
                            return intervalCount > 1 ? `${intervalCount} months` : 'month';
                        case "year":
                            return intervalCount > 1 ? `${intervalCount} years` : 'year';
                        default:
                            return interval;
                    }
                }

                function fmt(n) {
                    return '$' + parseFloat(n).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                }

                const lineItems = [
                    <apex:repeat value="{!quoteLinesData}" var="ql">
                        {
                        name:            "{!JSINHTMLENCODE(ql.productName)}",
                        description:     "{!JSINHTMLENCODE(ql.productDescription)}",
                        chargeType:      "{!ql.chargeType}",
                        effectiveQty:    {!ql.effectiveQuantity},
                        listPrice:       {!IF(ISNULL(ql.listPrice), 0, ql.listPrice)},
                        mrr:             {!IF(ISNULL(ql.mrr), 0, ql.mrr)},
                        netTotal:        {!IF(ISNULL(ql.netTotal), 0, ql.netTotal)},
                        discountPct:     {!IF(ISNULL(ql.discountPercent), 0, ql.discountPercent)},
                        discountFlat:    {!IF(ISNULL(ql.additionalDiscountAmount), 0, ql.additionalDiscountAmount)},
                        billingFreqOverride: "{!ql.billingFrequencyOverride}",
                        subscriptionTerm: {!IF(ISNULL(ql.subscriptionTerm), 0, ql.subscriptionTerm)}
                        },
                    </apex:repeat>
                ].filter(li => li.effectiveQty > 0);

                const container = document.getElementById('line-items-container');
                const billingFreq = "{!quoteData.billingFrequencyOverride}";

                // Track grand totals for the summary footer
                let grandListTotal  = 0;
                let grandFinalTotal = 0;
                let hasAnyDiscount  = false;

                lineItems.forEach(li => {
                    const hasDiscount  = li.discountPct > 0 || li.discountFlat > 0;
                    const isRecurring  = li.chargeType === 'Recurring';
                    const freq         = li.billingFreqOverride || billingFreq;

                    const finalAmt     = cycleAmount(li);
                    const listAmt      = listCycleAmount(li);
                    const unitAmt      = unitCycleAmount(li);
                    const listUnitAmt  = listUnitCycleAmount(li);
                    const label        = isRecurring ? cycleLabel(freq) : '';
                    const intLabel     = isRecurring ? freqIntervalLabel(freq) : '';
                    const discountFlat = calculateFlatDiscount(listAmt, finalAmt);

                    grandFinalTotal += finalAmt;
                    grandListTotal  += listAmt;
                    if (hasDiscount) hasAnyDiscount = true;

                    // Discount pill — shown on the RIGHT of the sub-row
                    let pillHtml = '';
                    if (li.discountPct > 0) {
                        pillHtml = `<span class="discount-pill discount-pct">${li.discountPct}% off</span>`;
                    } else if (discountFlat > 0) {
                        pillHtml = `<span class="discount-pill discount-flat">$${discountFlat.toFixed(2)} off</span>`;
                    }

                    // Price column: show strikethrough list price only when there's a real discount
                    const priceColHtml =
                        `<div class="item-price-block">
                            ${hasDiscount 
                                ? `<div class="item-list-price">${fmt(listAmt)}</div>` 
                                : ''
                            }
                            <div class="item-final-price">${fmt(finalAmt)}</div>
                        </div>`;

                    // Breakdown line: e.g. "3 × $300.00 / year → $240.00 / year after discount"
                    const breakdownLine =
                        `<div class="li-breakdown">
                            ${hasDiscount
                                ? `<span class="old-price">
                                    ${li.effectiveQty} &times; ${fmt(listUnitAmt)}
                                  </span>`
                                : ''
                            }
                            ${li.effectiveQty} &times; ${fmt(unitAmt)} = ${fmt(finalAmt)} ${isRecurring ? `every ${intLabel}` : ''}
                        </div>`

                    // Sub-row: qty badge + billing label LEFT, discount pill RIGHT
                    const html = `
                        <div class="li-block">
                            <div class="line-item-name-row">
                                <span style="font-weight:600;font-size:13px">${li.name}</span>
                                ${priceColHtml}
                            </div>
                            ${li.description ? `<div class="product-desc">${li.description}</div>` : ''}
                            ${breakdownLine}
                            <div class="line-item-sub-row">
                                <div class="li-sub-left">
                                    <span class="qty-badge">Qty ${li.effectiveQty}</span>
                                </div>
                                ${pillHtml}
                            </div>
                        </div>`;

                    container.insertAdjacentHTML('beforeend', html);
                });

                // ── Totals summary block rendered below all line items ──
                if (lineItems.length > 0) {
                    const savingsAmt = grandListTotal - grandFinalTotal;

                    let totalsHtml = `<div class="${hasAnyDiscount ? "totals-block-discount" : "totals-block"}">`;

                    if (hasAnyDiscount) {
                        // Subtotal before discounts + discounts row
                        totalsHtml += `
                            <div class="totals-row">
                                <span>Subtotal (before discounts)</span>
                                <span>${fmt(grandListTotal)}</span>
                            </div>
                            <div class="totals-row totals-row--discount">
                                <span>Discounts applied</span>
                                <span>&minus;${fmt(savingsAmt)}</span>
                            </div>`;
                    }

                    // Total per cycle
                    totalsHtml += `
                        <div class="totals-row totals-row--total">
                            <span>Total</span>
                            <span>${fmt(grandFinalTotal)}</span>
                        </div>`;

                    // Savings note
                    if (hasAnyDiscount && savingsAmt > 0) {
                        totalsHtml += `
                            <div class="totals-savings">
                                &#10003; You're saving ${fmt(savingsAmt)} with applied discounts
                            </div>`;
                    }

                    totalsHtml += `</div>`;
                    container.insertAdjacentHTML('beforeend', totalsHtml);
                }

                // ------------------------------------
                // TC Scroll Enforcement
                // ------------------------------------
                function handleTosScroll(el) {
                    var threshold = 20; // px from bottom counts as "read"
                    if (el.scrollTop + el.clientHeight >= el.scrollHeight - threshold) {
                        var cb = document.getElementById("terms-checkbox");
                        if (cb.disabled) {
                            cb.disabled = false;
                            var hint = document.getElementById("tos-scroll-hint");
                            hint.textContent = "✓ You've read the MSA — please check the box to agree.";
                            hint.style.color = "#22c55e";
                            var unread = document.getElementById("msa-unread-note");
                            if (unread) unread.style.display = "none";
                            var unlockNote = document.getElementById("scroll-unlock-note");
                            if (unlockNote) unlockNote.style.display = "none";
                        }
                    }
                    checkFormReady();
                }

                // ------------------------------------
                // Submit Button Enablement
                // ------------------------------------
                function checkFormReady() {
                    var firstName = (document.getElementById("billing-first-name").value || "").trim();
                    var lastName = (document.getElementById("billing-last-name").value || "").trim();
                    var email = (document.getElementById("billing-email").value || "").trim();
                    var street = (document.getElementById("shipping-street").value || "").trim();
                    var city = (document.getElementById("shipping-city").value || "").trim();
                    var state = (document.getElementById("shipping-state").value || "").trim();
                    var postal = (document.getElementById("shipping-postal").value || "").trim();
                    var checked = document.getElementById("terms-checkbox").checked;
                    var signature = (document.getElementById("signature-input").value || "").trim();

                    var ready = firstName && lastName && email && street && city && state && postal && checked && signature;
                    document.getElementById("submit-btn").disabled = !ready;
                }

                // Attach checkFormReady to all required inputs
                document.addEventListener("DOMContentLoaded", function () {
                    var fields = ["billing-first-name", "billing-last-name", "billing-email",
                        "shipping-street", "shipping-city", "shipping-state",
                        "shipping-postal", "signature-input"];
                    fields.forEach(function (id) {
                        var el = document.getElementById(id);
                        if (el) el.addEventListener("input", checkFormReady);
                    });
                    document.getElementById("terms-checkbox").addEventListener("change", checkFormReady);
                });

                async function handlePay() {
                    if (paymentInProgress) return;
                    paymentInProgress = true;
                    setLoading(true);

                    try {
                        const termsChecked = document.getElementById("terms-checkbox").checked;
                        const signatureValue = document.getElementById("signature-input").value.trim();

                        // Billing contact
                        const billingFirstName = document.getElementById("billing-first-name").value.trim();
                        const billingLastName = document.getElementById("billing-last-name").value.trim();
                        const billingEmail = document.getElementById("billing-email").value.trim();

                        // Shipping address
                        const shippingStreet = document.getElementById("shipping-street").value.trim();
                        const shippingCity = document.getElementById("shipping-city").value.trim();
                        const shippingState = document.getElementById("shipping-state").value.trim().toUpperCase();
                        const shippingPostal = document.getElementById("shipping-postal").value.trim();
                        const shippingCountry = document.getElementById("shipping-country").value.trim().toUpperCase() || "US";

                        if (!billingFirstName || !billingLastName) {
                            throw new Error("Please enter the billing contact first and last name.");
                        }
                        if (!billingEmail) {
                            throw new Error("Please enter the billing contact email.");
                        }
                        if (!shippingStreet || !shippingCity || !shippingState || !shippingPostal) {
                            throw new Error("Please complete the shipping address (street, city, state, and postal code are required).");
                        }

                        if (!termsChecked) {
                            throw new Error("You must agree to the Master Services Agreement before continuing.");
                        }

                        if (!signatureValue) {
                            throw new Error("Please provide your digital signature.");
                        }

                        const billToName = billingFirstName + " " + billingLastName;
                        postCheckoutUpdate(signatureValue, billToName, billingEmail, shippingStreet, shippingCity, shippingState, shippingCountry, shippingPostal);

                        const result = await actions.confirm({
                            returnUrl: "{!$Label.SuccessUrlForPayment}"
                        });

                        if (result.type === "success") {
                            console.log("Payment successful:", result);
                        } else {
                            const errorMessage = result.error
                                ? result.error.message
                                : "Payment failed. Please try again.";
                            showToast(errorMessage, "error");
                            setLoading(false);
                            paymentInProgress = false;
                        }
                    } catch (error) {
                        showToast(error.message, "error");
                        setLoading(false);
                        paymentInProgress = false;
                    }
                }

                function postCheckoutUpdate(signatureValue, billToName, billToEmail, shippingStreet, shippingCity, shippingState, shippingCountry, shippingPostal) {
                    Visualforce.remoting.Manager.invokeAction(
                        "{!$RemoteAction.StripeCheckoutController.handleCheckoutCompletion}",
                        "{!quoteData.id}",
                        signatureValue,
                        "{!ipAddress}",
                        "{!userAgent}",
                        billToName,
                        billToEmail,
                        shippingStreet,
                        shippingCity,
                        shippingState,
                        shippingCountry,
                        shippingPostal,
                        function (result, event) {
                            if (event.status) {
                                console.log("Checkout completion handled successfully.");
                            } else {
                                console.error("Error handling checkout completion:", event.message);
                            }
                        },
                        { escape: true }
                    );
                }

                // ------------------------------------
                // UI Helpers
                // ------------------------------------

                function showToast(message, type) {
                    type = type || "error";
                    const toast = document.getElementById("toast");
                    const toastMessage = document.getElementById("toast-message");

                    toastMessage.textContent = message;

                    toast.classList.remove("error", "success");
                    toast.classList.add(type);
                    toast.classList.add("show");

                    setTimeout(() => {
                        toast.classList.remove("show");
                    }, 4000);
                }

                function setLoading(state) {
                    const submitButton = document.querySelector(".submit-btn");
                    submitButton.disabled = state;
                    submitButton.classList.toggle("loading", state);
                }
            </script>
        </body>
    </html>
</apex:page>
