<apex:page controller="StripeCheckoutController"
    showHeader="false"
    sidebar="false"
    standardStylesheets="false"
    cache="false"
    docType="html-5.0"
>
    <html>
        <head>
            <title>Checkout</title>
            <script src="https://js.stripe.com/clover/stripe.js"></script>
            <link rel="icon" type="image/png" href="{!URLFOR($Resource.Displai)}" />
            <link rel="preconnect" href="https://fonts.googleapis.com" />
            <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
            <link
                href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&amp;display=swap"
                rel="stylesheet"
            />
            <style>
                /* ========== GLOBAL ========== */
                body {
                    margin: 0;
                    font-family:
                        "Inter",
                        -apple-system,
                        BlinkMacSystemFont,
                        sans-serif;
                    background: #ffffff;
                    color: #1a1f36;
                }

                .container1 {
                    max-width: 280px;
                    margin: 240px auto;
                    text-align: center;
                    font-size: 14px;
                    color: #303036;
                }
                .container1 p {
                    font-size: 12px;
                }
                .container {
                    max-width: 1040px;
                    margin: 40px auto;
                    display: grid;
                    grid-template-columns: 1fr 1fr;
                    gap: 64px;
                }

                /* ========== LEFT SUMMARY ========== */
                .contract-card {
                    background: #f7f9fc;
                    border: 1px solid #e6ebf1;
                    border-radius: 12px;
                    padding: 16px 18px;
                    margin-bottom: 24px;
                }
                .contract-row {
                    display: flex;
                    justify-content: space-between;
                    font-size: 13px;
                    margin-bottom: 8px;
                }
                .contract-row:last-child {
                    margin-bottom: 0;
                }
                .contract-label {
                    color: #697386;
                    font-weight: 500;
                }
                .contract-value {
                    font-weight: 600;
                    color: #1a1f36;
                }

                .summary {
                    padding-top: 16px;
                }

                .summary h1 {
                    font-size: 16px;
                    font-weight: 600;
                    margin-bottom: 8px;
                }

                .price {
                    font-size: 48px;
                    font-weight: 800;
                    margin-bottom: 24px;
                }
                .interval {
                    font-size: 14px;
                    font-weight: 600;
                    color: #697386;
                    margin: 0;
                }

                .line-item {
                    display: flex;
                    justify-content: space-between;
                    font-size: 14px;
                    margin-bottom: 8px;
                }

                .muted {
                    display: flex;
                    justify-content: space-between;
                    font-size: 12px;
                    color: #697386;
                    margin-bottom: 22px;
                }
                .product-desc {
                    font-style: italic;
                    color: #697386;
                    font-size: 12px;
                    margin-top: -6px;
                    margin-bottom: 8px;
                }

                /* ========== RIGHT FORM ========== */
                .readonly {
                    position: relative;
                }
                .readonly label {
                    position: absolute;
                    bottom: 50%;
                    transform: translateY(50%);
                    padding: 8px 24px;
                    margin: 0;
                }
                .readonly input {
                    padding-top: 18px;
                    padding-bottom: 18px;
                    padding-left: 120px;
                }

                .checkout {
                    border-left: 1px solid #e6ebf1;
                    padding-left: 64px;
                }

                .section {
                    margin-bottom: 24px;
                }
                .section h2 {
                    font-size: 14px;
                    font-weight: 600;
                    margin-bottom: 12px;
                }

                #payment,
                #shipping-address {
                    display: none;
                }
                #payment.show,
                #shipping-address.show {
                    display: block;
                }

                label {
                    font-size: 12px;
                    font-weight: 500;
                    display: block;
                    margin-bottom: 6px;
                }

                .input-box,
                select {
                    width: 100%;
                    padding: 10px 12px;
                    font-size: 14px;
                    border: 1px solid #d0d5dd;
                    border-radius: 6px;
                    box-sizing: border-box;
                }

                .input-box:focus,
                select:focus {
                    outline: none;
                    border-color: #635bff;
                }

                .radio-group {
                    border: 1px solid #d0d5dd;
                    border-radius: 6px;
                    overflow: hidden;
                }

                .tos {
                    font-size: 12px;
                    color: #697386;
                }
                .tos a {
                    color: #635bff;
                    text-decoration: none;
                }
                .terms {
                    display: flex;
                    align-items: center;
                    gap: 8px;
                }

                .submit-btn {
                    position: relative;
                    width: 100%;
                    background: #635bff;
                    color: white;
                    font-size: 14px;
                    font-weight: 600;
                    border: none;
                    border-radius: 6px;
                    padding: 18px;
                    cursor: pointer;
                    margin-top: 12px;
                    transition: background 0.3s ease;
                }
                .submit-btn:hover {
                    background: #544cff;
                }
                .submit-btn:disabled {
                    background: #d0d5dd;
                    cursor: not-allowed;
                }

                /* Spinner hidden by default */
                .btn-spinner {
                    position: absolute;
                    bottom: 28%;
                    right: 20px;
                    width: 18px;
                    height: 18px;
                    border: 2px solid rgba(255, 255, 255, 0.4);
                    border-top: 2px solid #ffffff;
                    border-radius: 50%;
                    animation: spin 0.6s linear infinite;
                    display: none;
                }

                /* When loading */
                .submit-btn.loading .btn-spinner {
                    display: inline-block;
                }

                /* Smooth spin */
                @keyframes spin {
                    from {
                        transform: rotate(0deg);
                    }
                    to {
                        transform: rotate(360deg);
                    }
                }

                .toast {
                    position: fixed;
                    top: 30px;
                    right: 30px;
                    background: #1a1f36;
                    color: white;
                    padding: 14px 20px;
                    border-radius: 4px;
                    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
                    opacity: 0;
                    transform: translateX(60px);
                    pointer-events: none;
                    transition: all 0.3s ease;
                    z-index: 9999;
                    min-width: 260px;
                    font-size: 14px;
                }
                .toast.show {
                    opacity: 1;
                    transform: translateY(0);
                    pointer-events: auto;
                }
                .toast.error {
                    background: #e55353;
                }
                .toast.success {
                    background: #22c55e;
                }

                .footer {
                    font-size: 11px;
                    color: #697386;
                    text-align: center;
                    margin-top: 16px;
                }

                /* ========== TC SCROLL BOX ========== */
                .tos-scroll-wrapper {
                    position: relative;
                    margin-bottom: 14px;
                }
                .tos-scroll-box {
                    height: 250px;
                    overflow-y: scroll;
                    border: 1px solid #d0d5dd;
                    border-radius: 6px;
                    padding: 12px 14px;
                    font-size: 11px;
                    line-height: 1.6;
                    color: #4a4f5e;
                    background: #f7f9fc;
                    box-sizing: border-box;
                }
                .tos-scroll-box h3 {
                    font-size: 12px;
                    font-weight: 700;
                    color: #1a1f36;
                    margin: 0 0 8px 0;
                }
                .tos-scroll-box p {
                    margin: 0 0 10px 0;
                }
                .tos-scroll-box .tos-section {
                    margin-bottom: 12px;
                }
                .tos-scroll-box .tos-section-title {
                    font-weight: 700;
                    color: #1a1f36;
                }
                .tos-scroll-hint {
                    font-size: 11px;
                    color: #635bff;
                    text-align: center;
                    margin-top: 5px;
                    font-weight: 500;
                    transition: opacity 0.3s ease;
                }
                .tos-scroll-hint.hidden {
                    opacity: 0;
                    pointer-events: none;
                }
                /* Disabled checkbox styling */
                #terms-checkbox:disabled {
                    opacity: 0.35;
                    cursor: not-allowed;
                }
                #terms-checkbox:not(:disabled) {
                    cursor: pointer;
                }
            </style>
        </head>

        <body>
            <!-- EXPIRED STATE &amp; COMPLETE STATE -->
            <apex:outputPanel rendered="{!OR(status == 'complete', status == 'expired')}">
                <div class="container1">
                    <h4>You're all done here</h4>
                    <p>You've either completed your payment or this checkout session has timed out.</p>
                </div>
            </apex:outputPanel>

            <!-- OPEN STATE -->
            <apex:outputPanel rendered="{!status == 'open'}">
                <div class="container">
                    <!-- LEFT -->
                    <div class="summary">
                        <img
                            src="{!URLFOR($Resource.DisplaiLogo)}"
                            alt="Displai Logo"
                            width="120"
                            style="margin: -22px 0 -8px 0"
                        />

                        <h1>{!subscriptionHeadline}</h1>

                        <div class="price">
                            <span id="price-value"></span>
                            <apex:outputPanel rendered="{!AND(onetimeItemCount = 0, recurringItemCount > 0)}">
                                <span class="interval">per {!LOWER(interval)}</span>
                            </apex:outputPanel>
                            <apex:outputPanel rendered="{!AND(onetimeItemCount > 0, recurringItemCount > 0)}">
                                <p class="interval">Then ${!recurringAmount} per {!LOWER(interval)}</p>
                            </apex:outputPanel>
                        </div>

                        <div class="contract-card">
                            <div class="contract-row">
                                <span class="contract-label">Quote</span>
                                <span class="contract-value">#{!quoteData.quoteNumber}</span>
                            </div>
                            <div class="contract-row">
                                <span class="contract-label">Term</span>
                                <span class="contract-value"> {!quoteData.subscriptionTerm} months </span>
                            </div>
                            <div class="contract-row">
                                <span class="contract-label">Starts</span>
                                <span class="contract-value"> {!TEXT(quoteData.startDate)} </span>
                            </div>
                            <div class="contract-row">
                                <span class="contract-label">Ends</span>
                                <span class="contract-value"> {!TEXT(quoteData.endDate)} </span>
                            </div>
                            <div class="contract-row">
                                <span class="contract-label">Sales Rep</span>
                                <span class="contract-value"> {!quoteData.salesRepName} </span>
                            </div>
                        </div>

                        <apex:repeat value="{!quoteLinesData}" var="ql">
                            <div class="line-item">
                                <span style="font-weight: 500">{!ql.productName}</span>
                                <span>${!IF(ql.chargeType == 'Recurring', ql.mrr, ql.netTotal)}</span>
                            </div>
                            <apex:outputPanel rendered="{!NOT(ISBLANK(ql.productDescription))}">
                                <div class="product-desc">
                                    <span>{!ql.productDescription}</span>
                                </div>
                            </apex:outputPanel>
                            <div class="muted">
                                <span
                                    >Qty {!TEXT(ql.quantity)}
                                    <apex:outputPanel rendered="{!NOT(ISBLANK(ql.billingFrequencyOverride))}">
                                        &bull; Billed {!ql.billingFrequencyOverride}
                                    </apex:outputPanel>
                                </span>
                                <apex:outputPanel rendered="{!ql.quantity > 1}">
                                    <span>${!ql.listPrice} each</span>
                                </apex:outputPanel>
                            </div>
                        </apex:repeat>
                    </div>

                    <!-- RIGHT -->
                    <div class="checkout">
                        <div class="section">
                            <h2>Shipping information</h2>

                            <div class="readonly">
                                <label>Email</label>
                                <input
                                    id="email"
                                    class="input-box"
                                    type="email"
                                    value="{!quoteData.accountBillToEmail}"
                                    disabled="true"
                                />
                            </div>
                        </div>

                        <div id="shipping-address" class="section">
                            <h2>Shipping address</h2>
                            <div id="shipping-address-element"></div>
                        </div>

                        <div id="payment" class="section">
                            <h2>Payment method</h2>
                            <div id="payment-element"></div>
                        </div>

                        <div class="section tos">

                            <!-- ===== SCROLLABLE TC BOX ===== -->
                            <div class="tos-scroll-wrapper">
                                <div class="tos-scroll-box" id="tos-scroll-box" onscroll="handleTosScroll(this)">
