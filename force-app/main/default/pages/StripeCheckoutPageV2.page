                                </div>
                                <div class="tos-scroll-hint" id="tos-scroll-hint">&#8595; You must scroll through and read all terms to enable the checkbox below — do not skip ahead</div>
                            </div>
                            <!-- ===== END TC BOX ===== -->

                            <div class="terms">
                                <input type="checkbox" id="terms-checkbox" disabled="disabled" />
                                <p>
                                    I agree to Displai's
                                    <a href="https://www.displai.ai/terms-of-service/" target="_blank"
                                        >Terms of Service</a
                                    >
                                    and
                                    <a href="https://www.displai.ai/privacy-policy/" target="_blank">Privacy Policy</a>
                                </p>
                            </div>
                            <label style="margin-top: 12px">{!$Label.StripeSignatureLabel}</label>
                            <input
                                type="text"
                                id="signature-input"
                                class="input-box"
                                placeholder="Type your full name"
                            />
                        </div>

                        <button class="submit-btn" onclick="handlePay()">
                            <span class="btn-text">{!IF(recurringItemCount > 0, 'Subscribe', 'Pay')}</span>
                            <span class="btn-spinner"></span>
                        </button>

                        <div class="footer">
                            {!IF(recurringItemCount > 0, 'By subscribing, you authorize Displai to charge you according to the terms until you cancel.', 'By confirming your payment, you allow Displai to charge you for this payment and future payments in accordance with their terms.')}
                        </div>

                        <div class="footer">
                            Sales tax applicable in the following states: LA, AZ, OH, FL, CO, MO, MI, NY, TN, MA, CA, MD, ID, PA, TX
                        </div>

                        <div id="toast" class="toast">
                            <div class="toast-content">
                                <span id="toast-message"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </apex:outputPanel>

            <script>
                const stripe = Stripe("{!publishableKey}");
                const clientSecret = "{!clientSecret}";
                const checkoutSessionId = "{!sessionId}";

                let checkout;
                let actions;
                let paymentInProgress = false;

                initializeCheckout();

                async function initializeCheckout() {
                    const appearance = {
                        theme: "stripe",
                        inputs: "condensed",
                        labels: "floating",
                        variables: {
                            colorPrimary: "#635bff",
                            colorText: "#1a1f36",
                            colorBackground: "#ffffff",
                            colorDanger: "#e55353",
                            fontFamily: "Inter, -apple-system, BlinkMacSystemFont, sans-serif",
                            spacingUnit: "4px",
                            borderRadius: "6px"
                        },
                        rules: {
                            ".Input": {
                                backgroundColor: "#ffffff",
                                borderColor: "#d0d5dd",
                                boxShadow: "0 1px 2px 0 rgba(18, 52, 86, 0.05)",
                                padding: "10px 12px",
                                fontSize: "14px"
                            },
                            ".Input:focus": {
                                borderColor: "#635bff",
                                boxShadow: "0 1px 2px 0 rgba(99, 91, 255, 0.3)"
                            },
                            ".Input--error": {
                                borderColor: "#e55353",
                                boxShadow: "0 1px 2px 0 rgba(229, 83, 83, 0.3)"
                            },
                            ".Label": {
                                fontSize: "12px",
                                fontWeight: "500"
                            },
                            ".Label--floating": {
                                fontSize: "12px",
                                fontWeight: "500"
                            },
                            ".Label--resting": {
                                color: "#697386",
                                fontSize: "14px"
                            },
                            ".Error": {
                                color: "#e55353",
                                fontSize: "12px"
                            }
                        }
                    };

                    checkout = stripe.initCheckout({
                        clientSecret: clientSecret,
                        elementsOptions: {
                            appearance,
                            loader: "always",
                            fonts: [
                                {
                                    cssSrc: "https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&amp;display=swap"
                                }
                            ]
                        }
                    });

                    checkout.on("change", (session) => {
                        console.log("Checkout change event:", session);
                    });

                    const loadActionResult = await checkout.loadActions();
                    if (loadActionResult.type === "success") {
                        actions = loadActionResult.actions;
                        const session = loadActionResult.actions.getSession();
                        document.getElementById("price-value").textContent = session.total.total.amount;
                        console.log("Checkout actions loaded:", actions);
                    }

                    const paymentElement = checkout.createPaymentElement({
                        layout: {
                            type: "accordion",
                            defaultCollapsed: true,
                            radios: true,
                            spacedAccordionItems: false,
                            paymentMethodLogoPosition: "start"
                        }
                    });
                    paymentElement.mount("#payment-element");
                    document.getElementById("payment").classList.add("show");

                    const shippingAddressElement = checkout.createShippingAddressElement({
                        display: {
                            name: "full"
                        }
                    });
                    shippingAddressElement.mount("#shipping-address-element");
                    document.getElementById("shipping-address").classList.add("show");
                }

                // ------------------------------------
                // TC Scroll Enforcement
                // ------------------------------------
                function handleTosScroll(el) {
                    var threshold = 20; // px from bottom counts as "read"
                    if (el.scrollTop + el.clientHeight >= el.scrollHeight - threshold) {
                        var cb = document.getElementById("terms-checkbox");
                        if (cb.disabled) {
                            cb.disabled = false;
                            var hint = document.getElementById("tos-scroll-hint");
                            hint.textContent = "✓ You've read the terms — please check the box to agree.";
                            hint.style.color = "#22c55e";
                        }
                    }
                }

                async function handlePay() {
                    if (paymentInProgress) return;
                    paymentInProgress = true;
                    setLoading(true);

                    try {
                        const termsChecked = document.getElementById("terms-checkbox").checked;
                        const signatureValue = document.getElementById("signature-input").value.trim();

                        if (!termsChecked) {
                            throw new Error("You must agree to the Terms before continuing.");
                        }

                        if (!signatureValue) {
                            throw new Error("Please provide your digital signature.");
                        }

                        postCheckoutUpdate(signatureValue);

                        const result = await actions.confirm({
                            returnUrl: "{!$Label.SuccessUrlForPayment}"
                        });

                        if (result.type === "success") {
                            console.log("Payment successful:", result);
                        } else {
                            const errorMessage = result.error
                                ? result.error.message
                                : "Payment failed. Please try again.";
                            showToast(errorMessage, "error");
                            setLoading(false);
                            paymentInProgress = false;
                        }
                    } catch (error) {
                        showToast(error.message, "error");
                        setLoading(false);
                        paymentInProgress = false;
                    }
                }

                function postCheckoutUpdate(signatureValue) {
                    Visualforce.remoting.Manager.invokeAction(
                        "{!$RemoteAction.StripeCheckoutController.handleCheckoutCompletion}",
                        "{!quoteData.id}",
                        signatureValue,
                        "{!ipAddress}",
                        "{!userAgent}",
                        function (result, event) {
                            if (event.status) {
                                console.log("Checkout completion handled successfully.");
                            } else {
                                console.error("Error handling checkout completion:", event.message);
                            }
                        },
                        { escape: true }
                    );
                }

                // ------------------------------------
                // UI Helpers
                // ------------------------------------

                function showToast(message, type) {
                    type = type || "error";
                    const toast = document.getElementById("toast");
                    const toastMessage = document.getElementById("toast-message");

                    toastMessage.textContent = message;

                    toast.classList.remove("error", "success");
                    toast.classList.add(type);
                    toast.classList.add("show");

                    setTimeout(() => {
                        toast.classList.remove("show");
                    }, 4000);
                }

                function setLoading(state) {
                    const submitButton = document.querySelector(".submit-btn");
                    submitButton.disabled = state;
                    submitButton.classList.toggle("loading", state);
                }
            </script>
        </body>
    </html>
</apex:page>