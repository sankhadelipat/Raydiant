<apex:page showHeader="false" sidebar="false" standardStylesheets="false" cache="false" doctype="html-5.0">
    <html lang="en">
        <head>
            <meta charset="UTF-8" />
            <title>Payment Successful</title>
            <meta name="viewport" content="width=device-width, initial-scale=1.0" />
            <link rel="icon" type="image/png" href="{!URLFOR($Resource.Displai)}" />
            <link rel="preconnect" href="https://fonts.googleapis.com" />
            <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
            <link
                href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap"
                rel="stylesheet"
            />
            <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
            <style>
                * {
                    margin: 0;
                    padding: 0;
                    box-sizing: border-box;
                    font-family:
                        "Inter",
                        -apple-system,
                        BlinkMacSystemFont,
                        sans-serif;
                }

                body {
                    background: #f6f9fc;
                    min-height: 100vh;
                    display: flex;
                    justify-content: center;
                    align-items: center;
                }

                .container {
                    width: 100%;
                    max-width: 420px;
                    background: #ffffff;
                    border-radius: 12px;
                    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
                    padding: 32px;
                    text-align: center;
                }

                .logo img {
                    width: 110px;
                    margin-bottom: 20px;
                }

                .success-icon {
                    width: 56px;
                    height: 56px;
                    border-radius: 50%;
                    background: #e6f9f0;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    margin: 0 auto 16px;
                }

                .success-icon i {
                    color: #0a7d4f;
                    font-size: 22px;
                }

                h1 {
                    font-size: 20px;
                    color: #1a1f36;
                    margin-bottom: 8px;
                    font-weight: 600;
                }

                p {
                    font-size: 14px;
                    color: #6b7280;
                    margin-bottom: 24px;
                    line-height: 1.5;
                }

                .button {
                    display: inline-block;
                    width: 100%;
                    padding: 12px;
                    background: #635bff;
                    color: white;
                    text-decoration: none;
                    border-radius: 8px;
                    font-weight: 500;
                    font-size: 14px;
                    transition: all 0.2s ease;
                }

                .button:hover {
                    background: #5548ee;
                }

                .footer {
                    margin-top: 20px;
                    font-size: 12px;
                    color: #9ca3af;
                }
            </style>
        </head>
        <body>
            <div class="container">
                <div class="logo">
                    <img src="{!URLFOR($Resource.DisplaiLogo)}" alt="Logo" />
                </div>

                <div class="success-icon">
                    <i class="fas fa-check"></i>
                </div>

                <h1>Payment successful</h1>
                <p>Your payment has been processed successfully. You can now continue to your dashboard.</p>

                <a href="https://dash.raydiant.com/" class="button"> Go to Dashboard </a>

                <div class="footer">
                    <p>Need help? support@displai.com</p>
                </div>
            </div>
        </body>
    </html>
</apex:page>